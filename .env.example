# Copiá este archivo como .env y completá los valores

# ID del Google Sheet (está en la URL: docs.google.com/spreadsheets/d/ESTE_ID/edit)
SHEET_ID=tu_sheet_id_aqui

# Ruta al archivo JSON de credenciales de la service account
GOOGLE_CREDS_PATH=credentials.json

# PIN del administrador (cambialo por algo seguro)
ADMIN_PIN=1234

# Clave secreta de Flask (generá una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambiar-por-clave-aleatoria-segura

# Puerto donde corre la app (default 5000)
PORT=5000

# Activar modo debug solo en desarrollo (true/false)
FLASK_DEBUG=false
